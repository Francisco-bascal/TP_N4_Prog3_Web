@model IEnumerable<APP_PRUEBA_1.Models.Curso>

<h1 class="text-center mb-3">Cursos</h1>

<div class="d-flex justify-content-end align-items-center mb-3"> <!-- Sin data table sería between -->
    <!-- Inutilizado por Data Tables 
            <form method="get" asp-action="GetCursosByName" class="d-flex">
        <input type="text" name="busqueda" class="form-control me-2"
               placeholder="Buscar por nombre" />
        <button type="submit" class="btn btn-primary">Buscar</button>
    </form>
    -->
    <a asp-action="Create" class="btn btn-primary">Nuevo Curso</a>
</div>

<table id="tablaCursos" class="table table-bordered table-striped table-hover">
    <thead class="table-dark text-light">
        <tr>
            <th>ID</th>
            <th>Nombre</th>
            <th>Horas</th>
            <th>Fecha Inicio</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var curso in Model)
        {
            <tr>
                <td>@curso.IdCurso</td>
                <td>@curso.NombreCurso</td>
                <td>@curso.Horas</td>
                <td>@curso.FechaInicio</td>

                <td>
                    <a asp-action="Edit"
                       asp-route-id="@curso.IdCurso"
                       class="btn btn-warning btn-sm">
                        Editar
                    </a>

                    @if (User.IsInRole("Administrador"))
                    {
                        <button type="button"
                                class="btn btn-danger btn-sm"
                                data-bs-toggle="modal"
                                data-bs-target="#modalEliminar"
                                data-id="@curso.IdCurso"
                                data-nombre="@curso.NombreCurso">
                            Eliminar
                        </button>
                    }

                    <a asp-action="GetCursoById"
                       asp-route-id="@curso.IdCurso"
                       class="btn btn-primary btn-sm">

                        Detalles
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- Modal a nivel de vista -->
<div class="modal fade" id="modalEliminar" tabindex="-1" aria-labelledby="modalEliminarLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"
                    id="modalEliminarLabel">
                    Confirmar eliminación
                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>
            </div>
            <div class="modal-body">

                <p id="textoModal">
                    ¿Desea eliminar este registro?
                </p>

            </div>
            <div class="modal-footer">
                <button type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Cancelar
                </button>
                <form asp-action="Delete"
                      method="post">

                    <input type="hidden"
                           id="idEliminar"
                           name="id" />

                    <button type="submit"
                            class="btn btn-danger">
                        Eliminar
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts
{
    <script>
        new DataTable('#tablaCursos', {
            language: {
                url: '//cdn.datatables.net/plug-ins/2.3.3/i18n/es-ES.json'
            }
        });
    </script>

    <script>
        const modalEliminar = document.getElementById('modalEliminar');

        modalEliminar.addEventListener('show.bs.modal',
            function (event)
            {
                const boton = event.relatedTarget;
                const id = boton.getAttribute('data-id');
                const nombre = boton.getAttribute('data-nombre');
                
                document.getElementById('idEliminar').value = id;
                document.getElementById('textoModal').innerText = `¿Desea eliminar a ${nombre}?`;
            });
    </script>
}