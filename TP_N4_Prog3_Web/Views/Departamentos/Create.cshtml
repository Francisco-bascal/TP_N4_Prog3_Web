@model TP_N4_Prog3_Web.Models.Departamento

<h2 class="text-center mb-3">Nuevo Departamento</h2>

<div class="container d-flex justify-content-center align-items-center">

    <form asp-action="PostDepartamento" method="post">

        <div>
            <label>Nombre</label>
            <input asp-for="Nombre" class="form-control" />
        </div>

        <div>
            <label>Ubicación</label>
            <input asp-for="Ubicacion" class="form-control" />
        </div>

        <div asp-validation-summary="All" class="text-danger"/>

        <div class="container d-flex flex-lg-row justify-content-center align-items-center gap-2 p-3">
            <button class="btn btn-primary" type="submit">Guardar</button>
            <a asp-action="GetDepartamentos" class="btn btn-secondary">Volver</a>
        </div>
    </form>
</div>