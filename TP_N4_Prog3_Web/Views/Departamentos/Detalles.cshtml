<div class="d-flex flex-column justify-content-center align-items-center">
    <div class="card" style="max-width: 600px; min-width:300px">
        <div class="card-body">
            <div class="mb-2">
                <small class="text-muted">Identificador</small>
                <div class="fw-semibold">@Model.IdDepartamento</div>
            </div>
            <div>
                <small class="text-muted">Nombre</small>
                <div class="fs-5 fw-bold">@Model.Nombre</div>
            </div>
            <div>
                <small class="text-muted">Nombre</small>
                <div class="fs-5 fw-bold">@Model.Ubicacion</div>
            </div>
        </div>
    </div>
</div>