@model APP_PRUEBA_1.Models.Curso

<h2 class="text-center mb-3">Detalles</h2>

<div class="d-flex flex-column justify-content-center align-items-center">

    <div class="card" style="max-width: 600px; min-width:300px">

        <div class="card-body">

            <div class="mb-2">
                <small class="text-muted">Identificador</small>

                <div class="fw-semibold">
                    @Model.IdCurso
                </div>
            </div>

            <div class="mb-2">
                <small class="text-muted">Nombre del Curso</small>

                <div class="fs-5 fw-bold">
                    @Model.NombreCurso
                </div>
            </div>

            <div class="mb-2">
                <small class="text-muted">Horas</small>

                <div class="fs-5 fw-bold">
                    @Model.Horas
                </div>
            </div>

            <div>
                <small class="text-muted">Fecha de Inicio</small>

                <div class="fs-5 fw-bold">
                    @Model.FechaInicio
                </div>
            </div>

        </div>
    </div>
</div>