<div class="container mt-4">
    <h2 class="mb-4 text-center">Panel de Reportes</h2>
    <!-- Primera fila -->
    <div class="row mb-4">
        <!-- Card 1 -->
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title text-center">
                         Cantidad de Empleados por Departamento
                    </h5>

                    <p class="card-text">
                        Visualiza la cantidad de empleados que hay en cada departamento.
                    </p>

                    <a asp-controller="Reportes"
                       asp-action="EmpleadosPorDepartamento"
                       class="btn btn-primary mt-auto">
                        Ver Reporte
                    </a>
                </div>
            </div>
        </div>
        <!-- Card 2 -->
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title text-center">
                        Listado de Empleados por Cada Departamento
                    </h5>

                    <p class="card-text">
                        Reporte que lista los empleados que hay en cada departamento
                    </p>

                    <a asp-controller="Reportes"
                       asp-action="EmpleadosAgrupadosPorDepartamento"
                       class="btn btn-primary mt-auto">
                        Ver Reporte
                    </a>
                </div>
            </div>
        </div>
    </div>
    <!-- Segunda fila -->
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h4 class="card-title text-center">
                        Reporte Empleados por Curso
                    </h4>

                    <p class="card-text text-center">
                        Reporte de empleados asignados por curso
                    </p>

                    <div class="d-flex flex-column justify-content-center align-items-center">
                        <a asp-controller="Reportes"
                           asp-action="ReporteEmpleadosPorCurso"
                           class="btn btn-primary">
                            Ver Reporte
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Tercera fila -->
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h4 class="card-title text-center">
                        Reporte Avanzado
                    </h4>

                    <p class="card-text text-center">
                        Sección de reportes complejos con múltiples filtros,
                        estadísticas y visualizaciones.
                    </p>

                    <div class="d-flex flex-column justify-content-center align-items-center">
                        <a asp-controller="Reportes"
                           asp-action="ReporteFiltroEspecializado"
                           class="btn btn-dark">
                            Ir al Reporte Avanzado
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>