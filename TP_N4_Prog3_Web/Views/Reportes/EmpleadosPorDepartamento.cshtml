@using TP_N4_Prog3_Web.ViewModels
@model IEnumerable<EmpleadosPorDepartamentoVM>

<h2 class="text-center pb-3">Empleados por Departamento</h2>

<table id="tablaReporteEmpleadosDepartamento" class="table table-striped table-hover">
    <thead class="table-dark text-light">
        <tr>
            <th>Departamento</th>
            <th>Cantidad Empleados</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var depa in Model)
        {
            <tr>
                <td>@depa.Departamento</td>
                <td>@depa.CantidadEmpleados</td>
            </tr>
        }
    </tbody>
</table>

@section Scripts
{
    <script>
        new DataTable('#tablaReporteEmpleadosDepartamento', {
            language: {
                url: '//cdn.datatables.net/plug-ins/2.3.3/i18n/es-ES.json'
            }
        });
    </script>
}