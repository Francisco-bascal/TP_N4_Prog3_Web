@{
    ViewData["Title"] = "Inicio";
}

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card shadow">

                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">Sistema de Gestión de Recursos Humanos</h3>
                </div>

                <div class="card-body">

                    <p class="lead">
                        Bienvenido al sistema de gestión de Recursos Humanos.
                    </p>

                    <p>
                        Desde esta aplicación es posible administrar empleados,
                        departamentos, cursos y usuarios, de acuerdo con los permisos
                        asignados a cada perfil.
                    </p>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        @if (User.IsInRole("Operador"))
                        {
                            <p class="text-center">Bienvenido: Operador</p>
                        }

                        @if (User.IsInRole("Administrador"))
                        {
                            <p class="text-center">Bienvenido: Administrador</p>    
                        }

                    }

                    <hr />

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <h5 class="mb-3 text-center">
                            Accesos rápidos
                        </h5>

                        <div class="d-flex flex-row justify-content-center align-items-center gap-2">

                            <a asp-controller="Empleados"
                               asp-action="GetEmpleados"
                               class="btn btn-primary">
                                Empleados
                            </a>

                            <a asp-controller="Departamentos"
                               asp-action="GetDepartamentos"
                               class="btn btn-primary">
                                Departamentos
                            </a>

                            <a asp-controller="Cursos"
                               asp-action="GetCursos"
                               class="btn btn-primary">
                                Cursos
                            </a>

                            @if (User.IsInRole("Administrador"))
                            {
                                <a asp-controller="Usuarios"
                                   asp-action="GetUsuarios"
                                   class="btn btn-danger">
                                    Usuarios
                                </a>

                                <a asp-controller="Reportes"
                                   asp-action="Reportes"
                                   class="btn btn-danger">
                                    Reportes
                                </a>
                            }

                        </div>
                    }
                    else
                    {
                        <h5 class="mb-3 text-center">
                            Comenzar
                        </h5>

                        <div class="d-flex flex-row justify-content-center align-items-center gap-2">

                            <a asp-controller="Empleados"
                               asp-action="GetEmpleados"
                               class="btn btn-primary">
                                Ver Empleados
                            </a>

                            <a asp-controller="Auth"
                               asp-action="Login"
                               class="btn btn-success">
                                Iniciar Sesión
                            </a>

                            <a asp-controller="Auth"
                               asp-action="Registro"
                               class="btn btn-outline-primary">
                                Registrarse
                            </a>

                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>